{
  "name": "qml-preview",
  "publisher": "arkceajin",
  "displayName": "QML Preview",
  "description": "Preview QML files using qml.exe",
  "version": "0.3.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/arkceajin/qml-preview-extension.git"
  },
  "bugs": {
    "url": "https://github.com/arkceajin/qml-preview-extension/issues"
  },
  "homepage": "https://github.com/arkceajin/qml-preview-extension#readme",
  "keywords": [
    "qml",
    "qt",
    "cmake",
    "preview"
  ],
  "files": [
    "out/**",
    "src/**",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "workspaceContains:**/*.qml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "qmlPreview.selectQmlFile",
        "title": "QML Preview: Select QML File"
      },
      {
        "command": "qmlPreview.preview",
        "title": "QML Preview: Run Preview"
      }
    ],
    "keybindings": [
      {
        "command": "qmlPreview.preview",
        "key": "f7",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "QML Preview",
      "properties": {
        "qmlPreview.previewQmlFile": {
          "type": "string",
          "default": "",
          "description": "Workspace-relative path to the QML file to preview (e.g. ui/Main.qml). Leave empty to pick manually or auto-detect Main.qml."
        },
        "qmlPreview.qmlExecutable": {
          "type": "string",
          "default": "",
          "description": "Fallback path to qml.exe. Leave empty to auto-detect from Qt extension or CMakeCache."
        },
        "qmlPreview.qmlEnv": {
          "type": "string",
          "default": "QT_FORCE_STDERR_LOGGING=1 QT_LOGGING_TO_CONSOLE=1 QT_ASSUME_STDERR_HAS_CONSOLE=1",
          "description": "Environment variable assignments for qml process, e.g. KEY1=VALUE1 KEY2=VALUE2"
        },
        "qmlPreview.hotreload": {
          "type": "boolean",
          "default": true,
          "description": "Enable hot reload by launching qml through qmlpreview"
        },
        "qmlPreview.additionalImportPaths": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional QML import paths passed to qml via -I. Paths relative to the workspace root are resolved automatically."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.0.0"
  }
}
